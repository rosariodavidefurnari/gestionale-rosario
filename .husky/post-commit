HOOK="/Volumes/SSD ESTERNO/rag-stack/rag_git_hook.sh"
[ -x "$HOOK" ] || exit 0
REPO="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
# Refresh the local code-RAG in the background so the commit never blocks.
# .git/hooks/* is bypassed here because core.hooksPath points at .husky/_.
RAG_REPO="$REPO" "$HOOK" post-commit "$@" </dev/null >/dev/null 2>&1 &
exit 0
